fib fn(n i32) i32 =
	if n <= 1 then
		return n
	return (fib (n - 1)) + (fib (n - 2))

write syscall 1(fd u32, buf [u8], len u64) i32

print_int fn(i i32) i32 =
	let mut x i32 = i
	let mut idx u32 = 7
	let mut arr [u8; 8] = { 0, 0, 0, 0, 0, 0, 0, 0 }
	while x > 0 then
		let q i32 = x / 10
		let r i32 = x - (10 * q)
		arr[idx] = r + 48 as u8
		idx -= 1
		x = q
	write 1 arr 8
	return 0

pub main fn(argc i32) i32 =
	let mut x i32 = fib 35
	print_int x
	return 0
