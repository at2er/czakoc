write syscall 1(fd u32, buf [u8], len u64) i32
read syscall 0(fd u32, buf [u8], len u64) u64

pub main fn(argc i32) i32 =
	let mut idx u32 = 0
	let input [u8; 256] = {}
	let mut output [u8; 256] = {}
	read 0, input, 256
	while input[idx] != 0 then
		output[idx] = input[idx]
		idx += 1
	write 1, output, 256
	return 0
